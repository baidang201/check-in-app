# ============================================
# 打卡应用环境变量配置
# ============================================
# 这是配置示例，请复制这份文件为 .env，然后填入你的真实连接串
#
# 获取 MongoDB Atlas 连接串：
# 1. 登录 https://www.mongodb.com/atlas
# 2. 进入你的集群 → Connect
# 3. 选择 "Connect your application"
# 4. 复制连接串，将 <password> 替换为你的数据库用户密码
# ============================================

DATABASE_URL="mongodb+srv://myUser:myPassword@cluster0.xxxxx.mongodb.net/myFirstDatabase?retryWrites=true&w=majority"
